// ICSE/CBSE Project Tool — Prisma schema
// SQLite database storing: users, projects, agent runs, knowledge base, mocks, uploads

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============ Authentication ============

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String   // hashed via bcrypt
  board     String   @default("ICSE") // ICSE | CBSE
  className String   @default("10") @map("class_name")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}

// ============ Core entities ============

model Project {
  id          String      @id @default(cuid())
  title       String
  subject     String
  className   String      @map("class_name")
  topic       String
  board       String      @default("ICSE") // ICSE | CBSE
  userId      String?     @map("user_id")
  status      String      @default("pending")
  sourceText  String      @default("") @map("source_text")
  sourceName  String      @default("") @map("source_name")
  outline     String      @default("")
  finalOutput String      @default("") @map("final_output")
  images      String      @default("[]")
  agentLogs   String      @default("[]")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  mocks       Mock[]
}

model Mock {
  id          String   @id @default(cuid())
  projectId   String?  @map("project_id")
  subject     String
  className   String   @map("class_name")
  board       String   @default("ICSE")
  topic       String
  difficulty  String   @default("medium")
  questions   String
  duration    Int      @default(120)
  createdAt   DateTime @default(now()) @map("created_at")

  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

// ============ Knowledge base (RAG source) ============

model KnowledgeChunk {
  id          String   @id @default(cuid())
  board       String   @default("ICSE") // ICSE | CBSE | GENERAL
  subject     String
  className   String   @default("10") @map("class_name")
  category    String
  chapter     String   @default("")
  title       String
  content     String
  tags        String   @default("")
  source      String   @default("manual")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([board, subject, className, category])
  @@index([subject, chapter])
  @@index([board])
}

// ============ Cache ============

model CacheEntry {
  id          String   @id @default(cuid())
  cacheKey    String   @unique @map("cache_key")
  kind        String
  value       String
  createdAt   DateTime @default(now()) @map("created_at")
  hits        Int      @default(0)
}

model Upload {
  id          String   @id @default(cuid())
  filename    String
  mimeType    String   @map("mime_type")
  size        Int
  extractedText String @default("") @map("extracted_text")
  createdAt   DateTime @default(now()) @map("created_at")
}

model StudentProfile {
  id               String    @id @default(cuid())
  userId           String    @unique @map("user_id")
  learningStyle    String    @default("Socratic") // Socratic | Analogy | Visual | Practical | Direct
  interests        String    @default("[]")      // JSON list of interests
  strengths        String    @default("[]")      // JSON list of strengths
  weaknesses       String    @default("[]")      // JSON list of weaknesses
  studyHabits      String    @default("{}")      // JSON object of habits
  memoryLog        String    @default("[]")      // JSON array of key facts they struggle with
  lastAIExtraction DateTime? @map("last_ai_extraction")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
}

model StudyEvent {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  eventType String   @map("event_type") // tutor_chat | flashcard_recall | simulator_run | syllabus_toggle | mock_test
  subject   String
  topic     String
  metadata  String   @default("")      // JSON string of details (score, correct/incorrect, timeSpent, etc.)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, eventType])
  @@index([userId, subject])
}

model TimetableSlot {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  subject   String
  topic     String
  dayOfWeek String
  timeStart String
  timeEnd   String
  completed Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
}

model Task {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  date        String   // YYYY-MM-DD
  title       String
  completed   Boolean  @default(false)
  delayedFrom String?  @map("delayed_from") // YYYY-MM-DD
  delayReason String?  @map("delay_reason")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([userId, date])
}
